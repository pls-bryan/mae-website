---
import Layout from "../layouts/Layout.astro";
import SubpageHeader from "../components/SubpageHeader.astro";
import "../styles/global.css";
---

<Layout title="Merch | MAE" description="MAE merch coming soon">
  <main class="blank-page soon-page">
    <SubpageHeader title="MERCH" />
    <section class="soon-panel soon-panel--merch" aria-label="Merch coming soon">
      <p class="soon-panel__sign">
        <span>MERCH</span>
        <span>COMING</span>
        <span>SOON</span>
      </p>
    </section>
  </main>
</Layout>
