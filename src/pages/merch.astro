---
import Layout from "../layouts/Layout.astro";
import SubpageHeader from "../components/SubpageHeader.astro";
import "../styles/global.css";
---

<Layout title="Merch | MAE" description="MAE merch coming soon">
  <main class="blank-page soon-page">
    <SubpageHeader title="MERCH" />
    <section class="soon-panel">
      <p class="soon-panel__kicker">Coming Soon</p>
      <p class="soon-panel__title">The MAE merch drop is in progress.</p>
      <p class="soon-panel__body">
        This page will soon feature hats, apparel, and limited-run items tied to MAE
        programming and collaborations. Check back for the first release.
      </p>
    </section>
  </main>
</Layout>
